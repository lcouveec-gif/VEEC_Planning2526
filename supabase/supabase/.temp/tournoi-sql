-- Table des tournois
CREATE TABLE tournois (
  id         SERIAL PRIMARY KEY,
  slug       TEXT UNIQUE NOT NULL,
  nom        TEXT NOT NULL,
  date_debut DATE,
  date_fin   DATE,
  lieu       TEXT,
  created_at TIMESTAMPTZ DEFAULT NOW()
);

