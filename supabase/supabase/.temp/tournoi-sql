-- Table des inscriptions
CREATE TABLE inscriptions_tournoi (
  numero_billet      BIGINT PRIMARY KEY,
  tournoi_id         INT NOT NULL REFERENCES tournois(id),
  reference_commande BIGINT,
  date_commande      TIMESTAMPTZ,
  statut_commande    TEXT,
  nom_participant    TEXT,
  prenom_participant TEXT,
  nom_payeur         TEXT,
  prenom_payeur      TEXT,
  email_payeur       TEXT,
  moyen_paiement     TEXT,
  tarif              TEXT,
  montant_tarif      NUMERIC,
  code_promo         TEXT,
  montant_code_promo NUMERIC,
  email              TEXT,
  telephone          TEXT,
  custom_fields      JSONB,
  created_at         TIMESTAMPTZ DEFAULT NOW(),
  updated_at         TIMESTAMPTZ DEFAULT NOW()
);

-- Trigger updated_at
CREATE OR REPLACE FUNCTION update_updated_at()
RETURNS TRIGGER AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_updated_at
BEFORE UPDATE ON inscriptions_tournoi
FOR EACH ROW EXECUTE FUNCTION update_updated_at();

-- Index utiles
CREATE INDEX idx_tournoi_id   ON inscriptions_tournoi(tournoi_id);
CREATE INDEX idx_tarif        ON inscriptions_tournoi(tarif);
CREATE INDEX idx_statut       ON inscriptions_tournoi(statut_commande);
CREATE INDEX idx_custom       ON inscriptions_tournoi USING GIN(custom_fields);